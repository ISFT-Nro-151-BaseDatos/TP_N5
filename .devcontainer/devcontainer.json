{
    "name": "MariaDB Managed Environment",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "mtxr.sqltools",
                "mtxr.sqltools-driver-mysql"
            ]
        }
    },
    "remoteUser": "vscode",
    "postCreateCommand": "sudo service mariadb start && sudo mariadb -e \"CREATE DATABASE IF NOT EXISTS dev_db;\"",
    "postStartCommand": "sudo service mariadb start"
}